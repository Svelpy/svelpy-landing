---
// ClientCard.astro — Card de cliente / app desarrollada
import type { Client } from "../data/company";

interface Props {
  client: Client;
}

const { client } = Astro.props;
---

<a
  href={client.url}
  target="_blank"
  rel="noopener noreferrer"
  class="group block shadow-2xl drop-shadow-lg hover:shadow-[0_20px_40px_rgba(26,35,59,0.2)] transition-all duration-400 overflow-hidden"
>
  <!-- Imagen / Logo del cliente -->
  <div
    class="relative overflow-hidden bg-light-primary/5 h-44 flex items-center justify-center border-b border-light-primary/10"
  >
    <img
      src={client.logo}
      alt={`Logo de ${client.name}`}
      class="w-full h-full object-contain p-4 group-hover:scale-105 transition-transform duration-400"
      loading="lazy"
    />
    <!-- Badge de enlace externo -->
    <span
      class="absolute top-3 right-3 bg-light-primary text-light-white text-xs font-mono px-2 py-1 opacity-0 group-hover:opacity-100 transition-opacity duration-300"
    >
      Ver app ↗
    </span>
  </div>

  <!-- Contenido -->
  <div class="p-5 bg-light-background shadow-2xl drop-shadow-lg">
    <!-- Header: icono + nombre + empresa -->
    <div class="flex items-start gap-3 mb-3">
      <div class="min-w-0">
        <h3
          class="text-lg font-bold text-light-primary group-hover:text-light-secondary transition-colors duration-200"
        >
          {client.name}
        </h3>
        <p class="text-xs text-light-secondary font-mono truncate">
          📍 {client.company}
        </p>
      </div>
    </div>

    <!-- Descripción -->
    <p class="text-light-text-body text-sm leading-relaxed mb-4 line-clamp-3">
      {client.description}
    </p>
  </div>
</a>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
