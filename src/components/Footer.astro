---
// Footer.astro — Footer de Svelpy
import GitHubIcon from "./icons/GitHubIcon.astro";
import LinkedInIcon from "./icons/LinkedInIcon.astro";
import MailIcon from "./icons/MailIcon.astro";
import WhatsappIcon from "./icons/WhatsappIcon.astro";
import { companyInfo } from "../data/company";
const year = new Date().getFullYear();
---

<footer class="bg-light-background py-12 px-4 border-t border-light-primary/20">
  <div class="max-w-6xl mx-auto">
    <!-- Fila principal -->
    <div
      class="flex flex-col lg:flex-row items-center justify-between gap-8 mb-8"
    >
      <!-- Logo y slogan -->
      <div class="text-center lg:text-left">
        <h2
          class="text-light-white text-2xl font-mono font-bold bg-light-accent px-4 py-1 inline-block rotate-1 mb-2"
        >
          &lt;Svelpy/&gt;
        </h2>
        <p class="text-light-text-body text-sm mt-2">
          {companyInfo.tagline}
        </p>
        <p class="text-light-text-body text-xs mt-1">
          📍 {companyInfo.location}
        </p>
      </div>

      <!-- Links de navegación -->
      <nav class="flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm">
        <a
          href="#nosotros"
          class="text-light-text-body hover:text-light-secondary transition-colors"
          >Nosotros</a
        >
        <a
          href="#servicios"
          class="text-light-text-body hover:text-light-secondary transition-colors"
          >Servicios</a
        >
        <a
          href="#casos"
          class="text-light-text-body hover:text-light-secondary transition-colors"
          >Casos de Éxito</a
        >

        <a
          href="#contacto"
          class="text-light-text-body hover:text-light-secondary transition-colors"
          >Contacto</a
        >
      </nav>

      <!-- Social links -->
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href={`mailto:${companyInfo.email}`}
          aria-label="Email"
          class="text-light-secondary hover:text-light-primary transition flex gap-1 flex-col items-center rotate-2"
        >
          <MailIcon />
          <span class="text-xs">Email</span>
        </a>
        <a
          href={`https://wa.me/${companyInfo.whatsapp?.replace(/\D/g, "")}`}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="WhatsApp"
          class="text-light-secondary hover:text-light-primary transition flex gap-1 flex-col items-center -rotate-2"
        >
          <WhatsappIcon />
          <span class="text-xs">WhatsApp</span>
        </a>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-light-primary/20 pt-6">
      <div
        class="flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-light-text-body"
      >
        <p>© {year} {companyInfo.name}. Todos los derechos reservados.</p>

        <!-- Links legales -->
        <nav class="flex gap-4" aria-label="Legal">
          <a
            href="/privacidad"
            class="hover:text-light-secondary transition-colors"
          >
            Política de Privacidad
          </a>
          <span>·</span>
          <a
            href="/terminos"
            class="hover:text-light-secondary transition-colors"
          >
            Términos y Condiciones
          </a>
          <span>·</span>
          <a
            href="/cookies"
            class="hover:text-light-secondary transition-colors"
          >
            Cookies
          </a>
        </nav>
      </div>
    </div>
  </div>
</footer>
