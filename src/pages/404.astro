---
// 404.astro — Página de error personalizada
import LegalLayout from "../layouts/LegalLayout.astro";
---

<LegalLayout
  title="Página no encontrada"
  description="La página que buscas no existe en Svelpy."
>
  <div class="min-h-[60vh] flex flex-col items-center justify-center text-center py-20">
    <!-- Código de error estilo terminal -->
    <div class="font-mono text-8xl md:text-9xl font-bold text-light-primary mb-4 animate-float">
      404
    </div>

    <div class="font-mono text-light-accent text-lg mb-6 bg-light-background px-6 py-3 shadow-lg rotate-1">
      &lt;PaginaNoEncontrada /&gt;
    </div>

    <h1 class="text-3xl font-bold text-light-primary mb-4">
      Ups, esta página no existe
    </h1>

    <p class="text-xl text-light-text-body max-w-md mx-auto leading-relaxed mb-10">
      La URL que ingresaste no está en nuestro servidor. Puede haber sido movida, 
      eliminada o nunca existió.
    </p>

    <!-- Opciones de navegación -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
      <a
        href="/"
        class="px-8 py-3 bg-light-primary text-light-white hover:shadow-lg hover:shadow-light-primary transition-all duration-300 hover:scale-105 font-medium"
      >
        ← Volver al inicio
      </a>
      <a
        href="/#contacto"
        class="px-8 py-3 border border-light-primary text-light-primary hover:border-light-secondary hover:text-light-secondary transition-all duration-300 hover:scale-105 font-medium"
      >
        Contactar a Svelpy
      </a>
    </div>

    <!-- Links rápidos -->
    <div class="text-sm text-light-text-body">
      <p class="mb-3 font-medium text-light-primary">¿Buscabas alguna de estas secciones?</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/#nosotros" class="hover:text-light-secondary transition-colors">Nosotros</a>
        <a href="/#servicios" class="hover:text-light-secondary transition-colors">Servicios</a>
        <a href="/#casos" class="hover:text-light-secondary transition-colors">Casos de Éxito</a>
        <a href="/#stack" class="hover:text-light-secondary transition-colors">Stack</a>
        <a href="/#contacto" class="hover:text-light-secondary transition-colors">Contacto</a>
      </div>
    </div>
  </div>
</LegalLayout>
