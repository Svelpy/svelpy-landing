---
// LegalLayout.astro
// Layout para páginas legales con navegación mínima
import { companyInfo } from "../data/company";
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Información legal de Svelpy Software." } =
  Astro.props;

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, follow" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link
      href="https://fonts.googleapis.com/css2?family=Freckle+Face&display=swap"
      rel="stylesheet"
    />
    <title>{title} — Svelpy</title>
    <style>
      .bg-grid-pattern {
        background-image:
          linear-gradient(
            to right,
            var(--color-light-primary) 1px,
            transparent 1px
          ),
          linear-gradient(
            to bottom,
            var(--color-light-primary) 1px,
            transparent 1px
          );
        background-size: 20px 20px;
      }
    </style>
  </head>
  <body class="bg-light-background overflow-x-hidden">
    <!-- Fondo cuadriculado -->
    <div class="fixed inset-0 -z-10">
      <div class="absolute inset-0 bg-grid-pattern opacity-20"></div>
    </div>

    <!-- Nav mínima -->
    <nav class="fixed top-0 left-0 right-0 z-50 px-4">
      <div class="max-w-4xl mx-auto px-6 py-4">
        <div class="flex items-center justify-between">
          <a
            href="#hero"
            class="text-2xl font-mono font-bold text-light-primary hover:text-light-secondary transition-colors duration-200"
          >
            <div class="flex items-center justify-center">
              <img
                src="/logo.png"
                alt="Svelpy Logo"
                class="size-10 md:size-14"
              />
              <h1 class="font-bold text-[#4CA9A1] font-mono md:text-2xl">
                {companyInfo.name}
              </h1>
            </div>
          </a>
          <a
            href="/"
            class="text-sm text-light-primary hover:text-light-secondary transition-colors border border-light-primary hover:border-light-secondary px-4 py-2"
          >
            ← Volver al inicio
          </a>
        </div>
      </div>
    </nav>

    <main class="max-w-4xl mx-auto px-6 pt-32 pb-20">
      <!-- Breadcrumb -->
      <div
        class="flex items-center gap-2 text-sm text-light-text-body mb-8 font-mono"
      >
        <a href="/" class="hover:text-light-secondary transition-colors"
          >Inicio</a
        >
        <span>/</span>
        <span class="text-light-accent">{title}</span>
      </div>

      <slot />
    </main>

    <!-- Footer mínimo -->
    <footer class="border-t border-light-primary/20 py-8 px-4">
      <div
        class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-light-text-body"
      >
        <span>© {year} Svelpy. Todos los derechos reservados.</span>
        <div class="flex gap-6">
          <a
            href="/privacidad"
            class="hover:text-light-secondary transition-colors">Privacidad</a
          >
          <a
            href="/terminos"
            class="hover:text-light-secondary transition-colors">Términos</a
          >
          <a
            href="/cookies"
            class="hover:text-light-secondary transition-colors">Cookies</a
          >
        </div>
      </div>
    </footer>
  </body>
</html>
